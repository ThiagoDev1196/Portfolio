---
import { Image } from "astro:assets";
import pfp from "../assets/testimg2.jpg";
---

<div
  class="about-container flex flex-col justify-center items-center bg-[#0D0D0D] sm:flex-row-reverse sm:pt-5 h-screen w-full sm:p-6 md:justify-around"
>
  <div
    class="about-img-container p-8 h-auto max-w-80 md:max-w-none sm:flex sm:justify-center sm:items-center"
  >
    <Image
      class="mt-10 sm:mt-0 max-h-65 md:max-h-96 md:w-96 lg:max-h-100 lg:w-100 md:aspect-square border-black border-4 rounded-full object-cover"
      alt="profile picture"
      src={pfp}
    />
  </div>

  <div
    class="about-text-container text-white flex flex-col justify-center items-center sm:items-start sm:space-y-1 lg:space-y-5"
  >
    <p class="text-gray-500 sm:text-lg md:text-2xl lg:text-3xl">
      Hi, I'm Thiago and I am a
    </p>
    <h1 class="text-3xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-blue-500">
      Front-end developer
    </h1>

    <div class="about-button-container pt-4 space-x-2 sm:space-y-2 sm:text-lg">
      <button
        class="bg-white text-black px-4 py-2 rounded-lg border-2 border-white cursor-pointer md:text-2xl lg:text-3xl"
        >See my projects</button
      >
      <button
        class="bg-black px-4 py-2 rounded-lg border-2 border-white cursor-pointer md:text-2xl lg:text-3xl"
        >Contact me</button
      >
    </div>
  </div>
</div>
