---
const { name, picture } = Astro.props;
---

<div
  class="skill-container border-3 border-white w-28 h-28 rounded-md text-white text-center flex flex-col items-center justify-center space-y-1 sm:w-32 sm:h-32 md:w-36 md:h-36 lg:w-40 lg:h-40"
>
  <div class="skill-text-container">
    <span class="text-md md:text-lg">{name}</span>
  </div>

  <div class="skill-img mx-auto flex shrink-0">
    <img class="object-contain w-14 h-14 sm:w-16 sm:h-16 md:w-18 md:h-18 lg:w-20 lg:h-20" src={picture} alt={`${name} logo`} />
  </div>
</div>

<style>
  img {
    filter: invert(1) brightness(2);
    opacity: 0.9;
  }
</style>
